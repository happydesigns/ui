{
  "name": "@h4designs/ui",
  "type": "module",
  "version": "0.13.5",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "author": "happydesigns",
  "homepage": "https://github.com/happydesigns",
  "exports": {
    ".": "./nuxt.config.ts",
    "./schemas": "./schemas/index.ts"
  },
  "main": "./nuxt.config.ts",
  "files": [
    "app",
    "content.config.ts",
    "nuxt.config.ts",
    "schemas"
  ],
  "scripts": {
    "dev": "nuxt dev playground",
    "docs": "nuxt dev docs --extends docus",
    "prepare": "nuxt prepare && nuxt prepare playground",
    "build": "nuxt build playground",
    "preview": "nuxt preview playground",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "changelogen --release",
    "release:pre": "changelogen --release --prerelease",
    "release:alpha": "changelogen --release --versionSuffix alpha.0",
    "release:beta": "changelogen --release --versionSuffix beta.0"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.101",
    "@iconify-json/simple-icons": "^1.2.76",
    "@nuxt/content": "^3.12.0",
    "@nuxt/ui": "^4.6.1",
    "better-sqlite3": "^12.8.0",
    "nuxt-studio": "^1.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@antfu/ni": "^30.0.0",
    "@nuxt/eslint": "^1.15.2",
    "changelogen": "^0.6.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "nuxt": "^4.4.2",
    "nuxt-content-traits": "^0.1.2",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "resolutions": {
    "@h4designs/ui": "workspace:*"
  }
}
