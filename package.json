{
  "name": "@h4designs/ui",
  "type": "module",
  "version": "0.7.0",
  "packageManager": "pnpm@10.32.1",
  "author": "happydesigns",
  "homepage": "https://github.com/happydesigns",
  "exports": {
    ".": "./nuxt.config.ts",
    "./schemas": "./schemas/index.ts"
  },
  "main": "./nuxt.config.ts",
  "files": [
    "app",
    "schemas",
    "nuxt.config.ts",
    "content.config.ts"
  ],
  "scripts": {
    "dev": "nuxt dev playground",
    "docs": "nuxt dev docs --extends docus",
    "prepare": "nuxt prepare && nuxt prepare playground",
    "build": "nuxt build playground",
    "preview": "nuxt preview playground",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "changelogen --release",
    "release:pre": "changelogen --release --prerelease",
    "release:alpha": "changelogen --release --versionSuffix alpha.0",
    "release:beta": "changelogen --release --versionSuffix beta.0"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.97",
    "@iconify-json/simple-icons": "^1.2.73",
    "@nuxt/content": "^3.12.0",
    "@nuxt/ui": "^4.5.1",
    "better-sqlite3": "^12.6.2",
    "nuxt-studio": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@antfu/ni": "^28.3.0",
    "@nuxt/eslint": "^1.15.2",
    "changelogen": "^0.6.2",
    "eslint": "^10.0.3",
    "nuxt": "^4.4.2",
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@h4designs/ui": "workspace:*"
  }
}
